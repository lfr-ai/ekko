# Local HTTPS reverse proxy.
#
# Docker:  docker compose -f docker/compose.yaml -f docker/compose.override.yaml --profile caddy up
# Native:  UPSTREAM=localhost:$EKKO_PORT caddy run --config caddy/Caddyfile --adapter caddyfile
#
# Trust the CA to silence browser warnings: caddy trust

import snippets/*.caddy

{
	import global_base
}

localhost, 127.0.0.1, ::1 {
	tls internal

	import security_headers_base
	import app_routes {$UPSTREAM}
}
