{
  // ═══════════════════════════════════════════════════════════════════════════
  // Python Configuration
  // ═══════════════════════════════════════════════════════════════════════════
  "python.languageServer": "Pylance",
  "python.defaultInterpreterPath": "${workspaceFolder}/backend/.venv/Scripts/python.exe",
  "python.terminal.activateEnvironment": false,
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.inlayHints.variableTypes": true,
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": [
    "tests",
    "--no-cov"
  ],

  // ═══════════════════════════════════════════════════════════════════════════
  // GitHub Copilot Configuration
  // ═══════════════════════════════════════════════════════════════════════════

  // Enable GitHub Copilot
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "scminput": false,
    "yaml": true
  },

  // Copilot editor settings
  "github.copilot.editor.enableAutoCompletions": true,
  "github.copilot.editor.enableCodeActions": true,

  // Copilot chat settings
  "github.copilot.chat.localeOverride": "en",
  "github.copilot.chat.followUps": "on",
  "github.copilot.chat.runCommand.enabled": true,
  "github.copilot.chat.terminalChatLocation": "quickChat",

  // Use Claude via GitHub Copilot (requires GitHub Copilot subscription with model choice)
  // Note: This requires GitHub Copilot with model selection enabled
  "github.copilot.chat.model": "claude-3.5-sonnet",

  // Copilot agent customizations
  "github.copilot.chat.codeGeneration.instructions": [
    {
      "text": "Follow Clean Architecture principles with strict layer boundaries"
    },
    {
      "text": "Use Python 3.12+ features and full type hints on all functions"
    },
    {
      "text": "Use @dataclass(frozen=True, slots=True) for immutable data classes"
    },
    {
      "text": "Use structlog for logging, never print() statements"
    },
    {
      "text": "Document exceptions in docstrings only if directly raised in function body"
    },
    {
      "text": "Extract magic strings to Final[str] constants"
    },
    {
      "text": "Use keyword-only arguments (*) for 3+ parameters"
    }
  ],

  // Workspace instructions location
  "chat.instructionsFilesLocations": {
    ".github/instructions": true
  },
  "chat.agent.maxRequests": 250,
  "chat.detectParticipant.enabled": false,
  "chat.useAgentSkills": true,

  // Copilot next-edit suggestions
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.nextEditSuggestions.allowWhitespaceOnlyChanges": false,
  "github.copilot.chat.codesearch.enabled": true,

  // ═══════════════════════════════════════════════════════════════════════════
  // Editor Configuration
  // ═══════════════════════════════════════════════════════════════════════════
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.rulers": [120],
  "editor.inlayHints.enabled": "on",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.linkedEditing": true,
  "editor.suggest.preview": true,
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": true
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // Terminal Configuration
  // ═══════════════════════════════════════════════════════════════════════════
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.env.windows": {
    "EKKO_ENVIRONMENT": "local"
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // Files Configuration
  // ═══════════════════════════════════════════════════════════════════════════
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/.mypy_cache": true,
    "**/.hypothesis": true,
    "**/node_modules": true,
    "**/.venv": true,
    "**/dist": true,
    "**/build": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/.venv/**": true,
    "**/dist/**": true,
    "**/build/**": true
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // Search Configuration
  // ═══════════════════════════════════════════════════════════════════════════
  "search.exclude": {
    "**/node_modules": true,
    "**/.venv": true,
    "**/dist": true,
    "**/build": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/logs": true
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // Language-Specific Formatters
  // ═══════════════════════════════════════════════════════════════════════════
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    },
    "editor.formatOnSave": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "quickfix.biome": "explicit",
      "source.organizeImports.biome": "explicit"
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "quickfix.biome": "explicit",
      "source.organizeImports.biome": "explicit"
    }
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
    "editor.formatOnSave": true,
    "editor.wordWrap": "on"
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // Testing Configuration
  // ═══════════════════════════════════════════════════════════════════════════
  "playwright.reuseBrowser": false,
  "playwright.showTrace": false,

  // ═══════════════════════════════════════════════════════════════════════════
  // Git Configuration
  // ═══════════════════════════════════════════════════════════════════════════
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.suggestSmartCommit": false,
  "gitlens.telemetry.enabled": false,

  // ═══════════════════════════════════════════════════════════════════════════
  // Task Configuration
  // ═══════════════════════════════════════════════════════════════════════════
  "task.autoDetect": "on",
  "task.problemMatchers.neverPrompt": true,

  // ═══════════════════════════════════════════════════════════════════════════
  // Error Lens Configuration
  // ═══════════════════════════════════════════════════════════════════════════
  "errorLens.enabledDiagnosticLevels": [
    "error",
    "warning",
    "info"
  ],
  "errorLens.excludeBySource": [
    "cSpell"
  ],

  // ═══════════════════════════════════════════════════════════════════════════
  // Code Spell Checker Configuration
  // ═══════════════════════════════════════════════════════════════════════════
  "cSpell.enabled": true,
  "cSpell.words": [
    "ekko",
    "dataclass",
    "structlog",
    "crewai",
    "alembic",
    "pydantic",
    "fastapi",
    "uvicorn",
    "sqlalchemy",
    "aiosqlite",
    "langchain",
    "tiktoken",
    "pytest",
    "zustand",
    "shadcn",
    "tailwindcss",
    "biome",
    "biomejs",
    "vite"
  ],

  // ═══════════════════════════════════════════════════════════════════════════
  // Tailwind CSS Configuration
  // ═══════════════════════════════════════════════════════════════════════════
  "tailwindCSS.experimental.classRegex": [
    ["cn\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"]
  ],

  // ═══════════════════════════════════════════════════════════════════════════
  // TODO Highlight Configuration
  // ═══════════════════════════════════════════════════════════════════════════
  "todohighlight.keywords": [
    {
      "text": "TODO:",
      "color": "#ff6b6b",
      "backgroundColor": "transparent",
      "overviewRulerColor": "#ff6b6b"
    },
    {
      "text": "FIXME:",
      "color": "#ffa502",
      "backgroundColor": "transparent",
      "overviewRulerColor": "#ffa502"
    },
    {
      "text": "NOTE:",
      "color": "#5352ed",
      "backgroundColor": "transparent",
      "overviewRulerColor": "#5352ed"
    },
    {
      "text": "HACK:",
      "color": "#ff4757",
      "backgroundColor": "transparent",
      "overviewRulerColor": "#ff4757"
    }
  ]
}
