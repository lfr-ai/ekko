# =================================================================
# Docker Build Context Ignore for Production Containerfile
# =================================================================
# This file defines what to exclude when building the production
# Docker image from docker/Containerfile
#
# Build context is the project root, so paths are relative to root

# ---------------------------------------------------------------
# OS and Editor Files
# ---------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
*.cab
*.msi
*.msix
*.lnk
.idea/
.vscode/
*.swp
*.swo
*~
*.code-workspace

# ---------------------------------------------------------------
# Git
# ---------------------------------------------------------------
.git/
.github/
.gitignore
.gitattributes
.gitnexus/

# ---------------------------------------------------------------
# Python Development
# ---------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg
*.manifest
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/
backend/.venv/

# Testing and coverage
.pytest_cache/
.hypothesis/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.cache
nosetests.xml
.benchmarks/

# Type checkers and linters
.mypy_cache/
.ty/
.ty_cache/
.pyre/
.pytype/
.dmypy.json
dmypy.json
cython_debug/
.ruff_cache/
.tox/
.nox/

# ---------------------------------------------------------------
# Frontend (Not needed in backend image)
# ---------------------------------------------------------------
frontend/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*
*.tsbuildinfo
.eslintcache
.biome/
storybook-static/

# ---------------------------------------------------------------
# Tests (Not needed in production)
# ---------------------------------------------------------------
tests/
backend/tests/
*.test.py
*_test.py
test_*.py

# ---------------------------------------------------------------
# Documentation
# ---------------------------------------------------------------
docs/
*.md
!README.md
LICENSE
CHANGELOG.md
CONTRIBUTING.md

# ---------------------------------------------------------------
# Configuration Files (Development only)
# ---------------------------------------------------------------
.env.local
.env.*.local
.env.example
.env.local.example
.editorconfig
.pre-commit-config.yaml
.secrets.baseline
.hadolint.yaml
.lychee.toml
.markdownlint-cli2.yaml
.yamllint.yaml
.typos.toml
.shellcheckrc
.coderabbit.yaml
.redocly.yaml
.spectral.yaml
.jscpd.json
.cz.toml
.coveragerc
pytest.ini
tox.ini
ruff.toml
bandit.toml
ty.toml

# ---------------------------------------------------------------
# Development Tools
# ---------------------------------------------------------------
.devcontainer/
.claude/
.agents/
.gsd/
.gsd-id
.bg-shell/
.artifacts/

# ---------------------------------------------------------------
# Logs
# ---------------------------------------------------------------
*.log
logs/
backend/logs/

# ---------------------------------------------------------------
# Local Data and Storage
# ---------------------------------------------------------------
*.sqlite
*.sqlite3
*.sqlite3-journal
*.db
*.db-journal
backend/ekko.db
backend/ekko.db-*
uploads/
storage/
data/

# ---------------------------------------------------------------
# Build Artifacts
# ---------------------------------------------------------------
caddy/
docker/
Taskfile.yml
tasks/
tools/
registry/
scripts/

# ---------------------------------------------------------------
# Temporary Files
# ---------------------------------------------------------------
*.tmp
*.temp
*.bak
*.old
*~
.tmp/
tmp/

# ---------------------------------------------------------------
# Link Checker Cache
# ---------------------------------------------------------------
.lycheecache

# ---------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------
.ipynb_checkpoints

# ---------------------------------------------------------------
# MCP Configuration (Not needed in production)
# ---------------------------------------------------------------
.mcp.json
