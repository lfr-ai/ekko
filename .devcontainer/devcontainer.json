{
  "name": "Ekko Dev Container",
  "dockerComposeFile": "compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "postCreateCommand": "zsh scripts/bootstrap-uv.sh 2>/dev/null || bash -c 'pip install --upgrade pip && pip install uv pre-commit && cd backend && uv sync --all-extras && cd ../frontend && bun install && cd .. && uvx pre-commit install'",
  "remoteUser": "vscode",
  "forwardPorts": [8000, 3000, 5432, 6006],
  "mounts": [
    "source=ekko-uv-cache,target=/home/vscode/.cache/uv,type=volume",
    "source=ekko-precommit-cache,target=/home/vscode/.cache/pre-commit,type=volume",
    "source=ekko-zsh-history,target=/home/vscode/.zsh_history,type=volume"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "biomejs.biome",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml",
        "editorconfig.editorconfig",
        "DavidAnson.vscode-markdownlint",
        "streetsidesoftware.code-spell-checker",
        "github.copilot-chat",
        "bradlc.vscode-tailwindcss",
        "exiasr.hadolint",
        "timonwong.shellcheck",
        "samuelcolvin.jinjahtml"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "python.defaultInterpreterPath": "/workspace/backend/.venv/bin/python",
        "python.terminal.activateEnvironment": false,
        "editor.formatOnSave": true,
        "files.trimTrailingWhitespace": true,
        "files.eol": "\n",
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
          }
        },
        "[typescript][typescriptreact][javascript][json]": {
          "editor.defaultFormatter": "biomejs.biome"
        }
      }
    }
  }
}
