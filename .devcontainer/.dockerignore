# =================================================================
# Docker Build Context Ignore for DevContainer
# =================================================================
# This file defines what to exclude when building the development
# container from .devcontainer/Containerfile.dev

# ---------------------------------------------------------------
# OS and Editor Files
# ---------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
.idea/
*.swp
*.swo
*~

# ---------------------------------------------------------------
# Git (Keep .git for development)
# ---------------------------------------------------------------
.gitignore
.gitattributes

# ---------------------------------------------------------------
# Python Caches (Will be regenerated in container)
# ---------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.mypy_cache/
.pytest_cache/
.ruff_cache/
.hypothesis/
.ty/
.ty_cache/

# ---------------------------------------------------------------
# Virtual Environments (Will be created in container)
# ---------------------------------------------------------------
.venv/
venv/
ENV/
env/
backend/.venv/

# ---------------------------------------------------------------
# Frontend node_modules (Will be installed in container)
# ---------------------------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/build/
node_modules/

# ---------------------------------------------------------------
# Build Artifacts
# ---------------------------------------------------------------
dist/
build/
*.egg-info/

# ---------------------------------------------------------------
# Logs (Will be generated in container)
# ---------------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------------
# Local Data
# ---------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
backend/ekko.db*
uploads/
storage/

# ---------------------------------------------------------------
# Coverage Reports (Will be generated in container)
# ---------------------------------------------------------------
htmlcov/
.coverage
.coverage.*
coverage.xml

# ---------------------------------------------------------------
# Temporary Files
# ---------------------------------------------------------------
*.tmp
*.temp
*.bak
*~

# ---------------------------------------------------------------
# Link Checker Cache
# ---------------------------------------------------------------
.lycheecache

# ---------------------------------------------------------------
# Large Development Artifacts
# ---------------------------------------------------------------
.benchmarks/
storybook-static/
.artifacts/
.bg-shell/
