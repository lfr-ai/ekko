{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":rebaseStalePrs",
    ":enablePreCommit",
    "schedule:earlyMondays"
  ],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "enabledManagers": ["pep621", "pre-commit", "github-actions", "npm"],
  "packageRules": [
    {
      "description": "Group Python dependencies",
      "matchManagers": ["pep621"],
      "groupName": "python dependencies",
      "automerge": false
    },
    {
      "description": "Group GitHub Actions",
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "automerge": true
    },
    {
      "description": "Group npm/bun dependencies",
      "matchManagers": ["npm"],
      "groupName": "frontend dependencies",
      "automerge": false
    },
    {
      "description": "Group pre-commit hooks",
      "matchManagers": ["pre-commit"],
      "groupName": "pre-commit hooks",
      "automerge": true
    },
    {
      "description": "Auto-merge patch updates for dev dependencies",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
