{
  "mcpServers": {
    "context7": {
      "type": "url",
      "url": "https://mcp.context7.com/mcp"
    },
    "shadcn": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ],
      "cwd": "./frontend"
    },
    "gitnexus": {
      "type": "stdio",
      "command": "bunx",
      "args": [
        "gitnexus@latest",
        "mcp"
      ],
      "cwd": "."
    }
  }
}
