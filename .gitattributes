# Enforce LF for all text files across platforms
* text=auto eol=lf

# Explicitly mark source files as text with LF
*.py text eol=lf diff=python
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
*.sql text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.env.example text eol=lf

# Keep binary assets untouched by line-ending normalization
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
