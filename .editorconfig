root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{ts,tsx,js,jsx,css,html}]
indent_size = 2

[*.{yml,yaml,toml,json,jsonc}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[Dockerfile*]
indent_size = 4

[*.sh]
indent_size = 2
end_of_line = lf

[*.zsh]
indent_size = 2
end_of_line = lf
