{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":rebaseStalePrs",
    ":dependencyDashboard"
  ],
  "description": [
    "Repository-level Renovate config for automated dependency updates."
  ],
  "configMigration": true,
  "timezone": "Europe/Copenhagen",
  "schedule": [
    "after 6am and before 10pm on monday to friday"
  ],
  "prConcurrentLimit": 8,
  "prHourlyLimit": 2,
  "labels": [
    "dependencies"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 4am on monday"
    ]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security",
      "dependencies"
    ]
  },
  "enabledManagers": [
    "pre-commit",
    "pip_requirements",
    "pep621",
    "npm",
    "dockerfile",
    "docker-compose",
    "github-actions",
    "azure-pipelines"
  ],
  "rangeStrategy": "bump",
  "fetchChangeLogs": "off",
  "prCreation": "not-pending",
  "packageRules": [
    {
      "description": "Skip requires-python lookups to avoid python-version datasource noise",
      "matchManagers": ["pep621"],
      "matchDepTypes": ["requires-python"],
      "enabled": false
    },
    {
      "matchManagers": ["pep621"],
      "groupName": "python dependencies"
    },
    {
      "matchManagers": ["npm"],
      "groupName": "frontend dependencies"
    },
    {
      "description": "Group React ecosystem dependencies",
      "matchManagers": ["npm"],
      "matchPackageNames": [
        "react",
        "react-dom",
        "@types/react",
        "@types/react-dom"
      ],
      "groupName": "react ecosystem"
    },
    {
      "description": "Group frontend UI stack dependencies",
      "matchManagers": ["npm"],
      "matchPackageNames": [
        "tailwindcss",
        "@tailwindcss/vite",
        "@radix-ui/**",
        "class-variance-authority",
        "tailwind-merge",
        "tw-animate-css",
        "lucide-react",
        "storybook",
        "@storybook/**"
      ],
      "groupName": "frontend ui stack"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions dependencies"
    },
    {
      "matchManagers": ["dockerfile", "docker-compose"],
      "groupName": "container image dependencies"
    },
    {
      "description": "Require explicit approval for major dependency updates",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "automerge": false
    }
  ]
}
