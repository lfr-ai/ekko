{
    "id": "ekko-production-env",
    "name": "Ekko - Production (Desktop)",
    "values": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8000",
            "type": "default",
            "enabled": true,
            "description": "Production desktop app server URL"
        },
        {
            "key": "graphqlUrl",
            "value": "http://localhost:8000/graphql/graphql",
            "type": "default",
            "enabled": true,
            "description": "GraphQL endpoint URL"
        },
        {
            "key": "wsUrl",
            "value": "ws://localhost:8000/graphql/graphql",
            "type": "default",
            "enabled": true,
            "description": "WebSocket URL for GraphQL subscriptions"
        },
        {
            "key": "requestTimeoutMs",
            "value": "3000",
            "type": "default",
            "enabled": true,
            "description": "Stricter timeout for production SLA"
        }
    ],
    "_postman_variable_scope": "environment"
}
