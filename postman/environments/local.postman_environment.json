{
    "id": "ekko-local-env",
    "name": "Ekko - Local",
    "values": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8000",
            "type": "default",
            "enabled": true,
            "description": "Backend server URL"
        },
        {
            "key": "graphqlUrl",
            "value": "http://localhost:8000/graphql/graphql",
            "type": "default",
            "enabled": true,
            "description": "GraphQL endpoint URL"
        },
        {
            "key": "wsUrl",
            "value": "ws://localhost:8000/graphql/graphql",
            "type": "default",
            "enabled": true,
            "description": "WebSocket URL for GraphQL subscriptions"
        },
        {
            "key": "requestTimeoutMs",
            "value": "5000",
            "type": "default",
            "enabled": true,
            "description": "Maximum acceptable response time in ms"
        }
    ],
    "_postman_variable_scope": "environment"
}
