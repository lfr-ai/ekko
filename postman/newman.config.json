{
	"collection": "./ekko-api.postman_collection.json",
	"environment": "./environments/local.postman_environment.json",
	"reporters": [
		"cli",
		"junit"
	],
	"reporter": {
		"junit": {
			"export": "./reports/ekko-api-junit.xml"
		}
	},
	"iterationCount": 1,
	"delayRequest": 100,
	"timeoutRequest": 10000,
	"timeoutScript": 5000,
	"insecure": false,
	"bail": false,
	"color": "auto"
}
