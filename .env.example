# =============================================================================
# Ekko — Environment Variables
# =============================================================================
# Copy to `.env` for local development. Add `.env.local` for personal overrides.
# See compose.yml for which services consume which variables.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
EKKO_ENVIRONMENT=local          # local | test | staging | production
EKKO_HOST=127.0.0.1
EKKO_PORT=8000
EKKO_DEBUG=true
EKKO_LOG_LEVEL=DEBUG            # DEBUG | INFO | WARNING | ERROR
EKKO_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
EKKO_JWT_SECRET_KEY=change-me-ekko-jwt-secret
EKKO_JWT_EXPIRE_MINUTES=30
EKKO_JWT_ALGORITHM=HS256

# ── LLM / OpenAI ────────────────────────────────────────────────────────────
EKKO_LLM_PROVIDER=openai        # openai | azure_openai
EKKO_LLM_DEFAULT_DEPLOYMENT=gpt-4o
EKKO_OPENAI_API_KEY=
EKKO_AZURE_OPENAI_ENDPOINT=
EKKO_AZURE_OPENAI_KEY=

# ── PostgreSQL ───────────────────────────────────────────────────────────────
EKKO_POSTGRESQL_USER=postgres
EKKO_POSTGRESQL_PASSWORD=replace-with-db-password
EKKO_POSTGRESQL_HOST=127.0.0.1  # Use "postgres" when running in Docker
EKKO_POSTGRESQL_PORT=5432
EKKO_POSTGRESQL_NAME=ekko

# ── CrewAI / HMAS ───────────────────────────────────────────────────────────
EKKO_CREWAI_VERBOSE=false
EKKO_CREWAI_MAX_ITERATIONS=10
EKKO_HMAS_MAX_DEPTH=3

# ── PII Anonymization ───────────────────────────────────────────────────────
# All text is scrubbed BEFORE reaching LLM/HMAS agents.
EKKO_PII_ENABLED=true
EKKO_PII_PATTERNS=cpr,phone,email,address,credit_card

# ── Audio / STT ──────────────────────────────────────────────────────────────
EKKO_AUDIO_STREAMER_TCP_PORT=6600
EKKO_AUDIO_SAMPLE_RATE=48000
EKKO_AUDIO_CHANNELS=2
EKKO_STT_DEVICE=cpu             # cpu | cuda
EKKO_STT_COMPUTE_TYPE=default   # default | float16 | int8

# ── RAG / Embeddings ────────────────────────────────────────────────────────
EKKO_RAG_EMBEDDING_MODEL=text-embedding-3-small
EKKO_RAG_LLM_MODEL=gpt-4o

# ── Docker Compose ───────────────────────────────────────────────────────────
# These are consumed directly by compose.yml / compose.prod.yml.
COMPOSE_PROJECT_NAME=ekko
CADDY_DOMAIN=localhost
POSTGRES_USER=${EKKO_POSTGRESQL_USER:-postgres}
POSTGRES_PASSWORD=${EKKO_POSTGRESQL_PASSWORD:-replace-with-db-password}
POSTGRES_DB=${EKKO_POSTGRESQL_NAME:-ekko}
