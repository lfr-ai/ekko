# ─── Base Runtime Defaults ───────────────────────────────────────────────
# Shared defaults for all environments. Copy to `.env` and fill in values.
#
# Setup:  cp .env.example .env
#         (then fill in real values)
#
# Per-environment overrides live in the matching .env.<env> file.
# Resolution precedence: process env > .env.local > .env.<env> > .env
# ─────────────────────────────────────────────────────────────────────────

# ─── Docker Compose behavior ────────────────────────────────────────────
# Auto-load compose base+override files and both env files.
COMPOSE_PATH_SEPARATOR=:
COMPOSE_FILE=docker/compose.yaml:docker/compose.override.yaml
COMPOSE_ENV_FILES=.env,.env.local

# Optional observability profile (include compose.observability.yaml manually)
# Example:
# docker compose -f docker/compose.yaml -f docker/compose.override.yaml -f docker/compose.observability.yaml --profile observability up --build

# Optional analytics profile (include compose.analytics.yaml manually)
# Example:
# docker compose -f docker/compose.yaml -f docker/compose.override.yaml -f docker/compose.analytics.yaml --profile analytics up --build

# ─── Azure Speech Services (STT) — REQUIRED ─────────────────────────────
# Get your credentials from https://portal.azure.com
# Create a "Speech Services" resource and copy KEY 1 and REGION
EKKO_AZURE_SPEECH_KEY=
EKKO_AZURE_SPEECH_REGION=northeurope
EKKO_AZURE_SPEECH_LANGUAGE=da-DK

# ───────────────────────────────────────────────────────────
# OpenAI (LLM) - REQUIRED
# ───────────────────────────────────────────────────────────
# Get your API key from https://platform.openai.com/api-keys
EKKO_OPENAI_API_KEY=

# ───────────────────────────────────────────────────────────
# Azure OpenAI (Alternative to OpenAI) - OPTIONAL
# ───────────────────────────────────────────────────────────
# If using Azure OpenAI instead of OpenAI, uncomment and fill:
# EKKO_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# EKKO_AZURE_OPENAI_KEY=
# EKKO_AZURE_OPENAI_VERSION=2025-02-01-preview
# EKKO_LLM_PROVIDER=azure_openai

# ───────────────────────────────────────────────────────────
# Application Configuration
# ───────────────────────────────────────────────────────────
EKKO_ENVIRONMENT=local
EKKO_DEBUG=true
EKKO_HOST=127.0.0.1
EKKO_PORT=8000
EKKO_RELOAD=true

# ───────────────────────────────────────────────────────────
# Audio Configuration
# ───────────────────────────────────────────────────────────
# Set to true to disable audio capture (useful for testing)
EKKO_DISABLE_AUDIO=false
EKKO_AUDIO_STREAMER_TCP_PORT=6600
EKKO_AUDIO_SAMPLE_RATE=48000
EKKO_AUDIO_CHANNELS=2

# ───────────────────────────────────────────────────────────
# Database Configuration
# ───────────────────────────────────────────────────────────
EKKO_DATABASE_BACKEND=sqlite
EKKO_DATABASE_PATH=./ekko.db

EKKO_POSTGRESQL_HOST=127.0.0.1
EKKO_POSTGRESQL_PORT=5432
EKKO_POSTGRESQL_NAME=ekko
EKKO_POSTGRESQL_USER=postgres
# EKKO_POSTGRESQL_PASSWORD=
EKKO_POSTGRESQL_SSLMODE=prefer

# Optional full URL overrides (when set, these take precedence)
# EKKO_POSTGRESQL_ASYNC_DATABASE_URL_OVERRIDE=postgresql+asyncpg://user:pass@host:5432/ekko
# EKKO_POSTGRESQL_SYNC_DATABASE_URL_OVERRIDE=postgresql+psycopg://user:pass@host:5432/ekko

# Analytics store (independent from primary transactional backend)
EKKO_DUCKDB_ENABLED=false
EKKO_DUCKDB_DATABASE_PATH=./ekko_analytics.duckdb

# ───────────────────────────────────────────────────────────
# Logging Configuration
# ───────────────────────────────────────────────────────────
EKKO_LOG_LEVEL=INFO

# Optional Sentry DSN for error reporting
# EKKO_SENTRY_DSN=

# ───────────────────────────────────────────────────────────
# Local Observability (Docker profile) - OPTIONAL
# ───────────────────────────────────────────────────────────
EKKO_GRAFANA_ADMIN_USER=admin
EKKO_GRAFANA_ADMIN_PASSWORD=change-me
EKKO_GRAFANA_AUTH_ANONYMOUS_ENABLED=false

# Optional OpenTelemetry exporter endpoint for app instrumentation
# EKKO_OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

# Optional Grafana defaults for local observability profile
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_AUTH_ANONYMOUS_ENABLED=true

# ───────────────────────────────────────────────────────────
# Local Analytics (Matomo profile) - OPTIONAL
# ───────────────────────────────────────────────────────────
MATOMO_DB_ROOT_PASSWORD=matomo-root
MATOMO_DB_NAME=matomo
MATOMO_DB_USER=matomo
MATOMO_DB_PASSWORD=matomo

# ───────────────────────────────────────────────────────────
# RAG Configuration
# ───────────────────────────────────────────────────────────
EKKO_RAG_EMBEDDING_MODEL=text-embedding-3-small
EKKO_RAG_LLM_MODEL=gpt-4o

# ───────────────────────────────────────────────────────────
# Prompt Registry / Versioning
# ───────────────────────────────────────────────────────────
# Auto-provision new version files when prompt source content changes
EKKO_PROMPT_AUTO_PROVISION=true

# Optional: pin a specific version for all prompts (example: v2)
# EKKO_PROMPT_VERSION=v1
